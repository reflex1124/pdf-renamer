{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PDF Renamer",
  "version": "2.0.0",
  "identifier": "com.reflex1124.pdf-renamer",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PDF Renamer",
        "width": 1280,
        "height": 800,
        "minWidth": 1100,
        "minHeight": 720,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
