{
  "name": "pdf-renamer",
  "productName": "PDF Renamer",
  "version": "2.0.0",
  "description": "Electron-vite + React desktop app for analyzing PDFs and images with OpenAI, then safely renaming local files.",
  "main": "out/main/index.js",
  "scripts": {
    "clean": "rimraf out dist coverage",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "dev": "electron-vite dev",
    "build": "npm run clean && electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "dist:dir": "npm run build && electron-builder --dir"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reflex1124/pdf-renamer.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/reflex1124/pdf-renamer/issues"
  },
  "homepage": "https://github.com/reflex1124/pdf-renamer#readme",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/themes": "^3.3.0",
    "@tailwindcss/vite": "^4.2.1",
    "dotenv": "^17.3.1",
    "openai": "^6.29.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.2.4",
    "electron": "^38.3.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "jsdom": "^27.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.reflex1124.pdf-renamer",
    "productName": "PDF Renamer",
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "target": [
        "dmg",
        "dir"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis",
        "dir"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "directories": {
      "buildResources": "build",
      "output": "release"
    }
  }
}
