{
  "name": "pdf-renamer",
  "productName": "PDF Renamer",
  "version": "2.0.0",
  "description": "Electron + Astro desktop app for analyzing PDFs and images with OpenAI, then safely renaming local files.",
  "main": "dist/electron/electron/main.js",
  "scripts": {
    "clean": "rimraf dist .astro coverage",
    "typecheck": "astro check --config renderer/astro.config.mjs && tsc -p tsconfig.electron.json --noEmit",
    "test": "vitest run --coverage",
    "build:renderer": "astro build --config renderer/astro.config.mjs && node scripts/normalize-renderer-paths.mjs",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run clean && npm run build:renderer && npm run build:electron",
    "dev:renderer": "astro dev --config renderer/astro.config.mjs --host 127.0.0.1 --port 4321",
    "dev:electron:ts": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron:app": "wait-on dist/electron/electron/main.js tcp:127.0.0.1:4321 && nodemon --watch dist/electron --ext js,mjs,cjs --exec \"electron dist/electron/electron/main.js\"",
    "dev": "concurrently -k -n renderer,electron-ts,electron-app -c cyan,magenta,green \"npm:dev:renderer\" \"npm:dev:electron:ts\" \"npm:dev:electron:app\"",
    "dist": "npm run build && electron-builder",
    "dist:dir": "npm run build && electron-builder --dir"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reflex1124/pdf-renamer.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/reflex1124/pdf-renamer/issues"
  },
  "homepage": "https://github.com/reflex1124/pdf-renamer#readme",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^6.0.4",
    "dotenv": "^17.3.1",
    "openai": "^6.29.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1",
    "electron": "^38.3.0",
    "electron-builder": "^26.0.12",
    "jsdom": "^27.0.0",
    "nodemon": "^3.1.10",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.1"
  },
  "build": {
    "appId": "com.reflex1124.pdf-renamer",
    "productName": "PDF Renamer",
    "files": [
      "dist/electron/**/*",
      "dist/renderer/**/*",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "target": [
        "dmg",
        "dir"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis",
        "dir"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "directories": {
      "buildResources": "build",
      "output": "release"
    }
  }
}
